    boolean notequalsRecursive(Node3<popoxakan> i,Node3<popoxakan> j){

        if(i == null && j == null){
            System.out.println("2");
            return false;
        }

        if((i == null && j != null) || (i!=null && j==null)){
            System.out.println("1");
