    boolean equals(BinarySearchTree<popoxakan> n){
        /*
        Node i = n.skizb;
        Node j = skizb;
        boolean fl = equals_recursive(i,j);
        return fl;
    */
        return  equalsRecursive(n.skizb,skizb);
