    public String toString(){
        Node2<popoxakan> a = head;
        String str = "";
        while(a != null){
            str = str + a.value + "\n";
            a = a.next;
        }
        return str;
    }

    public boolean equals(PriorityQueue<popoxakan> a){
        if(qanak != a.qanak){
            return false;
        }
        Node2<popoxakan> n = head;
        Node2<popoxakan> m = a.head;
        for(int i = 0; i < qanak; i++){
            if(n.value != m.value){
                return false;
            }
            n = n.next;
            m = m.next;
        }
        return true;
    }
    void print(){
        Node2<popoxakan> a = head;
        System.out.println( "here--");
        while(a != null){
            System.out.println(a.value);
            a = a.next;
        }
    }
    void printrevers(){
        Node2<popoxakan> b = tail;
        System.out.println("revers:");
        while(b != null){
            System.out.println(b.value);
            b = b.previous;
        }
    }
}
