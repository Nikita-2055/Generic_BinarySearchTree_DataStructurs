import java.util.Comparator;

class Node2<anorosh>{
    anorosh value;
    Node2<anorosh> next;
    Node2<anorosh> previous;
    public Node2(anorosh x){
        value = x;
    }
}

public class PriorityQueue <popoxakan>{
    public Node2<popoxakan> head;
    public Node2<popoxakan> tail;
    Comparator<popoxakan> comparator;
    public  PriorityQueue(Comparator<popoxakan>  c){
        comparator = c;
    }
    public int qanak = 0;

    public PriorityQueue() {
        System.out.println("--call of default constructor");
    }

    Node2<popoxakan> find(popoxakan x){
        Node2<popoxakan> k = head;
        while (k != null){
            if(comparator.compare(x, k.value) == 0){
                return k;
            }
            k = k.next;
        }
        return null;
    }


    void push(popoxakan x) {
        Node2<popoxakan> n = new Node2<>(x);

        if (head == null) {
            head = tail = n;
            qanak++;
            return;
        }

        if (comparator.compare(x, head.value) <= 0) {
            n.next = head;
            head.previous = n;
            head = n;
            qanak++;
            return;
        }

        if (comparator.compare(x, tail.value) > 0) {
            n.previous = tail;
            tail.next = n;
            tail = n;
            qanak++;
            return;
        }


        Node2<popoxakan> k = head;
        while (k != null && comparator.compare(k.value, x) <= 0) {
            k = k.next;
        }

        n.next = k;
        n.previous = k.previous;
        k.previous.next = n;
        k.previous = n;

        qanak++;
    }
